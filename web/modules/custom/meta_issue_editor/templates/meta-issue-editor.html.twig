{#
/**
 * @file
 * Template for the Meta-Issue-Editor page.
 *
 * Variables:
 * - issue_number: The issue number being edited (if any).
 */
#}
<div class="meta-issue-editor-page">
  <div class="dashboard-navigation">
    <div class="nav-links">
      <a href="/ai-dashboard" class="nav-link">Dashboard</a>
      <a href="/ai-dashboard/calendar" class="nav-link">Calendar View</a>
      <a href="/ai-dashboard/calendar/organizational" class="nav-link">Organizational View</a>
      <a href="/ai-dashboard/roadmap" class="nav-link">Roadmap</a>
      <a href="/ai-dashboard/priority-kanban" class="nav-link">Kanban</a>
      <a href="/ai-dashboard/projects" class="nav-link">Projects</a>
      <a href="/ai-dashboard/docs" class="nav-link">Docs</a>
      <a href="/ai-dashboard/meta-issue-editor" class="nav-link active">Meta Issue Editor</a>
    </div>
  </div>

  <div class="meta-issue-editor-wrapper">
  <div class="meta-issue-editor-toolbar">
    <label for="issue-number-input">Issue #</label>
    <input type="text"
           id="issue-number-input"
           placeholder="e.g., 3456789"
           value="{{ issue_number }}"
           aria-label="Issue number">
    <button type="button" id="load-issue-btn" class="primary">Load</button>

    <span class="spacer"></span>

    <button type="button" id="import-md-btn" class="secondary">Import MD</button>

    <div class="dropdown">
      <button type="button" id="export-html-btn" class="secondary">Export HTML</button>
      <button type="button" id="export-md-btn" class="secondary">Export MD</button>
    </div>

    {% if can_save %}
      <button type="button" id="save-draft-btn" class="primary">Save Draft</button>
    {% endif %}
  </div>

  <div class="editor-format-toolbar">
    <div class="format-group">
      <button type="button" data-format="bold" title="Bold (Alt+B)"><strong>B</strong></button>
      <button type="button" data-format="italic" title="Italic (Alt+I)"><em>I</em></button>
      <button type="button" data-format="strikeThrough" title="Strike-through">S</button>
      <button type="button" data-format="formatBlock" data-value="h2" title="Heading 2">H2</button>
      <button type="button" data-format="formatBlock" data-value="h3" title="Heading 3">H3</button>
      <button type="button" data-format="formatBlock" data-value="h4" title="Heading 4">H4</button>
      <button type="button" data-format="formatBlock" data-value="blockquote" title="Quote">Quote</button>
      <button type="button" data-format="formatBlock" data-value="pre" title="Code block">Code</button>
      <button type="button" data-action="create-link" title="Insert Link">Link</button>
      <button type="button" data-format="insertOrderedList" title="Numbered List">1. List</button>
      <button type="button" data-format="insertUnorderedList" title="Bullet List">• List</button>
      <button type="button" data-format="outdent" title="Outdent">Outdent</button>
      <button type="button" data-format="indent" title="Indent">Indent</button>
      <button type="button" id="insert-bullet-btn" title="Insert bullet below current row">+ Bullet</button>
    </div>

    <div class="insert-issue-group">
      <label for="insert-issue-number-input">Insert issue</label>
      <input type="text"
             id="insert-issue-number-input"
             placeholder="Issue #"
             aria-label="Issue number to insert">
      <label class="checkbox-inline">
        <input type="checkbox" id="insert-include-assigned" checked>
        include @assigned
      </label>
      <button type="button" id="insert-issue-btn" class="secondary">Add Issue</button>
    </div>
  </div>

  <div class="meta-issue-editor-content" id="meta-issue-editor-content">
    <p>Enter an issue number above and click "Load" to begin editing a meta-issue.</p>
    <p>Or paste content directly into this editor.</p>
  </div>

  <div class="meta-issue-editor-footer">
    <div class="unknown-issues-info">
      <strong id="unknown-issues-count">0</strong> unknown issues
    </div>

    {% if can_fetch %}
      <button type="button" id="fetch-unknown-btn" class="primary" disabled>
        Pull 0 Unknown Issues from Drupal.org
      </button>
    {% else %}
      <span class="fetch-disabled-message">Log in to fetch issues from drupal.org</span>
    {% endif %}

    <span id="editor-status" class="status-message"></span>
  </div>
</div>
</div>
